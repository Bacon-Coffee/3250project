# 实验产物（图与 csv 会在 results/ 下重新生成，避免污染仓库历史）
results/figures/*.png
results/figures/*.pdf
results/figures/*.svg
results/csv/*.csv
!results/figures/.gitkeep
!results/csv/.gitkeep

# 真实 trace（体积大，需手动下载到 data/bitbrains/）
data/bitbrains/*.csv
data/bitbrains/*.zip
!data/bitbrains/.gitkeep

